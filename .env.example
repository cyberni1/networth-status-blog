# ===================== DATABASE =====================
# Neon PostgreSQL (https://neon.tech)
# Connection string with pgbouncer (pooled) - used at runtime
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ===================== AUTH =====================
# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Deployed URL (needed for NextAuth redirects)
# AUTH_URL="https://your-app.vercel.app"

# ===================== GOOGLE OAUTH =====================
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional: restrict sign-in to a specific Google Workspace domain
# GOOGLE_HOSTED_DOMAIN="yourcompany.com"

# ===================== AI =====================
# Anthropic API key for AI-powered meta generation
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
