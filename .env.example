# ===================== DATABASE =====================
# Neon PostgreSQL (https://neon.tech)
# Connection string with pgbouncer (pooled) - used at runtime
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ===================== ADMIN AUTH =====================
# Token-based admin authentication (no Google OAuth)
# Generate with: node scripts/generate-admin-token.js
CRON_SECRET="your-cron-secret-here"

# ===================== AI =====================
# Anthropic API key for AI-powered meta generation
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ===================== LIVE VOICE (TURN) =====================
# Optional but recommended for reliable voice across all networks.
# Without these, a best-effort public TURN fallback is used.
# Get free/paid credentials at e.g. https://www.metered.ca/tools/openrelay/ or Twilio.
TURN_URLS="turn:turn.example.com:3478,turns:turn.example.com:5349"
TURN_USERNAME="your-turn-username"
TURN_CREDENTIAL="your-turn-credential"
