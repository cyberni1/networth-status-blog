generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================== AUTH MODELS =====================

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?
  role      Role     @default(VIEWER)
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// ===================== BLOG MODELS =====================

model Post {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  content         String
  excerpt         String?
  metaTitle       String?
  metaDescription String?
  keywords        String?
  tags            String[]   @default([])
  category        Category
  coverImage      String?
  coverImageAlt   String?
  faq             String?    // JSON array of {question, answer}
  wealthData      String?    // JSON: {netWorth, currency, trend, trendPercent, yearChange, mainSource, sourceIcon, assets: [{label, percent, color}], incomeIcons: string[], annualIncome}
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  authorId        String
  author          User       @relation(fields: [authorId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([category])
  @@index([status])
  @@index([publishedAt])
}

enum Category {
  KUENSTLER
  SPORTLER
  UNTERNEHMER
  INFLUENCER
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model PostVote {
  id        String   @id @default(cuid())
  postId    String
  sessionId String   // anonymous session id
  stars     Int      // 1-5
  createdAt DateTime @default(now())

  @@unique([postId, sessionId])
  @@index([postId])
}

model SiteSetting {
  key       String   @id
  value     String   // base64 for images, text for other settings
  updatedAt DateTime @updatedAt
}

model AdminToken {
  id        String   @id @default(cuid())
  token     String   @unique // SHA-256 hashed token
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
  expiresAt DateTime?

  @@index([token])
}
